# DataStraw AI News Intelligence Platform
# Environment Configuration

# ===========================================
# AI Processing
# ===========================================
GROQ_API_KEY=your_groq_api_key_here
# Get your free API key at: https://console.groq.com
# Free tier: 30 requests/minute

# ===========================================
# News Data
# ===========================================
NEWSDATA_API_KEY=your_newsdata_api_key_here
# Get your free API key at: https://newsdata.io/api-keys
# Free tier: 200 requests/day

# ===========================================
# Weather Data (Optional)
# ===========================================
OPENWEATHER_API_KEY=your_openweather_api_key_here
# Get your free API key at: https://openweathermap.org/api
# Free tier: 1000 requests/day

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=sqlite:///./news_intelligence.db
# Default: SQLite (file-based database)
# For production PostgreSQL: postgresql://user:pass@host:5432/dbname

# ===========================================
# Security
# ===========================================
JWT_SECRET_KEY=your-random-secret-key-change-this-in-production
# Generate a secure random string for production
# Example: openssl rand -hex 32

# ===========================================
# Application Settings
# ===========================================
ENVIRONMENT=development
# Options: development, production

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings
CORS_ORIGINS=*
# For production, set specific domains: https://yourdomain.com,https://api.yourdomain.com

# ===========================================
# Feature Flags (Optional)
# ===========================================
ENABLE_AI_CHAT=true
ENABLE_MARKET_ANALYSIS=true
ENABLE_PREDICTIONS=true

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
