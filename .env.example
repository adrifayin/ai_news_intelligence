# ============================================
# DataStraw News Intelligence Platform
# Environment Configuration
# ============================================

# REQUIRED: AI Processing (Get from https://console.groq.com)
GROK_API_KEY=your_groq_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# REQUIRED: News Data (Get from https://newsdata.io)
NEWSDATA_API_KEY=your_newsdata_api_key_here

# REQUIRED: Weather Data (Get from https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# OPTIONAL: Additional News Sources
NEWSAPI_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_api_key_here
GUARDIAN_API_KEY=your_guardian_api_key_here

# OPTIONAL: Market Data APIs
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
MARKETSTACK_API_KEY=your_marketstack_key_here

# OPTIONAL: Twitter Integration
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# OPTIONAL: Additional AI Providers
COHERE_API_KEY=your_cohere_key_here

# Database Configuration
DATABASE_URL=sqlite:///./news_intelligence.db

# Pipeline Settings
ARTICLES_PER_FETCH=10
FETCH_CATEGORIES=technology,business,politics,science,sports

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
# 1. Copy this file to .env
# 2. Replace "your_*_key_here" with actual API keys
# 3. Minimum required: GROK_API_KEY, NEWSDATA_API_KEY, OPENWEATHER_API_KEY
# 4. Get free API keys from:
#    - Groq: https://console.groq.com (Free, fast AI)
#    - NewsData: https://newsdata.io (Free tier: 200 requests/day)
#    - OpenWeather: https://openweathermap.org/api (Free tier available)
